# Copy to `.env` for local development. In Vercel, add these as Environment Variables.
# Server-side variables (used by TanStack server functions and the auth attacher).
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side variables (used by the auto-generated Supabase integration client).
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key
VITE_SUPABASE_BUCKET=estate-images

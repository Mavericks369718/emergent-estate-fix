# Environment variables reference for Vercel deployment.
# NOTE: The app is pinned to the original South Delhi Estate Supabase project
# via hardcoded values in src/lib/supabase.ts. The frontend and admin client use
# those values, so the VITE_* and SUPABASE_* variables below are not strictly
# required for the app to run. However, the generated TanStack Start integration
# (src/integrations/supabase/*) expects them to be present, so add them to avoid
# build/runtime warnings.
#
# Replace these with the credentials from the SAME Supabase project where you
# created the estate-images bucket and ran the SQL policies:
SUPABASE_PROJECT_ID=adhdxazbzcrqufksunox
SUPABASE_URL=https://adhdxazbzcrqufksunox.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFkaGR4YXpiemNycXVma3N1bm94Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIwNDc0ODksImV4cCI6MjA5NzYyMzQ4OX0.RymH4aUg5h1SChUKU89QNLW_Kl0YhxrwPZiDQHOpcqw
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

VITE_SUPABASE_PROJECT_ID=adhdxazbzcrqufksunox
VITE_SUPABASE_URL=https://adhdxazbzcrqufksunox.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFkaGR4YXpiemNycXVma3N1bm94Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIwNDc0ODksImV4cCI6MjA5NzYyMzQ4OX0.RymH4aUg5h1SChUKU89QNLW_Kl0YhxrwPZiDQHOpcqw
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFkaGR4YXpiemNycXVma3N1bm94Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIwNDc0ODksImV4cCI6MjA5NzYyMzQ4OX0.RymH4aUg5h1SChUKU89QNLW_Kl0YhxrwPZiDQHOpcqw

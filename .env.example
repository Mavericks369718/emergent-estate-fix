# Environment variables for Vercel deployment.
# The app talks to Supabase directly from the browser — only the VITE_* keys
# are strictly needed at runtime. The SUPABASE_* mirrors are kept for the
# generated TanStack integration files so the build doesn't warn.
#
# All values below are PUBLIC (publishable). No service role key is required.
# Copy these values into Vercel → Environment Variables (or keep them in a
# local .env file that is NOT committed).

SUPABASE_PROJECT_ID=your-project-id
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_SUPABASE_BUCKET=estate-images
